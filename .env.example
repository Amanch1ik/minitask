# --- Database ---
POSTGRES_USER=minitask
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=minitask

# --- API ---
# Generate a real one for prod: `python -c "import secrets; print(secrets.token_urlsafe(48))"`
JWT_SECRET=dev-secret-do-not-use-in-production-please
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MIN=43200          # 30 days; tune for prod (15 min + refresh)
COOKIE_NAME=minitask_session
COOKIE_SECURE=false                 # set true behind HTTPS
COOKIE_SAMESITE=lax
CORS_ORIGINS=http://localhost:5173

# Base URL of the web app — used to build verify / reset links in emails.
PUBLIC_WEB_URL=http://localhost:5173

# Token lifetimes (minutes)
VERIFY_TOKEN_TTL_MIN=1440           # 1 day
RESET_TOKEN_TTL_MIN=60              # 1 hour

# --- Email ---
# Leave SMTP_HOST empty for the free dev backend: verify/reset links are printed
# to the API log instead of being emailed. Fill these in to send real mail
# (e.g. a free Gmail account with an app password).
EMAIL_FROM=minitask <no-reply@minitask.local>
SMTP_HOST=                          # e.g. smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                          # e.g. you@gmail.com
SMTP_PASSWORD=                      # Gmail app password (not your login password)
SMTP_TLS=true

# --- Web ---
VITE_API_URL=http://localhost:8000
